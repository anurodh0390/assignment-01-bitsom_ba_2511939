# !pip install sentence-transformers matplotlib seaborn

import numpy as np
import seaborn as sns
import matplotlib.pyplot as plt
from sentence_transformers import SentenceTransformer, util

# 1. Define 10 sentences across 3 topics
sentences = [
    # Cricket
    "The batsman hit a massive six over deep mid-wicket.",
    "Test matches require players to have immense patience and technique.",
    "The umpire signaled a wide after the ball swung too far down leg.",
    "Fielding at slip requires lightning-fast reflexes and focus.",
    # Cooking
    "Sauté the onions until they become translucent and slightly golden.",
    "Adding a pinch of salt can enhance the flavor of chocolate desserts.",
    "Kneading the dough thoroughly is essential for making soft bread.",
    # Cybersecurity
    "Implementing multi-factor authentication reduces the risk of unauthorized access.",
    "Phishing attacks use deceptive emails to steal sensitive credentials.",
    "A robust firewall acts as a barrier against untrusted external traffic."
]

# 2. Generate embeddings using all-MiniLM-L6-v2
model = SentenceTransformer('all-MiniLM-L6-v2')
embeddings = model.encode(sentences)

# 3. Compute 10x10 Cosine Similarity Matrix
cosine_sim_matrix = util.cos_sim(embeddings, embeddings).numpy()

# 4. Display Heatmap
plt.figure(figsize=(10, 8))
sns.heatmap(cosine_sim_matrix, annot=True, cmap='YlGnBu', fmt=".2f")
plt.title("10x10 Cosine Similarity Matrix (Cricket, Cooking, Cybersecurity)")
plt.show()

# 5. New Query Similarity Search
query = "The bowler took three wickets in one over"
query_embedding = model.encode(query)

# Compute similarity scores for the query against all sentences
scores = util.cos_sim(query_embedding, embeddings)[0]

# Find top 2 most similar sentences
top_results = np.argsort(scores)[-2:][::-1]

print(f"\nQuery Sentence: '{query}'")
print("-" * 30)
for idx in top_results:
    print(f"Similar Sentence: {sentences[idx]}")
    print(f"Similarity Score: {scores[idx]:.4f}\n")